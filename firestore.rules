rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (matches auth.uid)
    // Fields:
    //   - username: string (required, max 30 chars, lowercase alphanumeric)
    //   - displayName: string (required, max 50 chars)
    //   - bio: string (optional, max 160 chars)
    //   - photoURL: string (optional, max 500 chars, valid URL)
    //   - theme: string (optional, max 20 chars)
    //
    // Collection: users/{userId}/links
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required, max 100 chars)
    //   - url: string (required, max 500 chars, valid URL)
    //   - order: number (required, positive)
    //   - isActive: boolean (required)
    //   - createdAt: timestamp (required, immutable)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }
    
    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }
    
    function isValidUrl(url) {
      return url is string &&
        (url.matches("^https://.*") || url.matches("^http://.*"));
    }
    
    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    
    function isValidUser() {
      return hasRequiredFields(['username', 'displayName']) &&
             hasOnlyAllowedFields(['username', 'displayName', 'bio', 'photoURL', 'theme']) &&
             validStringLength('username', 3, 30) &&
             request.resource.data.username.matches("^[a-z0-9_]+$") &&
             validStringLength('displayName', 1, 50) &&
             isValidOptionalString('bio', 0, 160) &&
             isValidOptionalString('theme', 1, 20) &&
             (!( 'photoURL' in request.resource.data ) || isValidUrl(request.resource.data.photoURL));
    }
    
    function isValidLink() {
      return hasRequiredFields(['title', 'url', 'order', 'isActive', 'createdAt']) &&
             hasOnlyAllowedFields(['title', 'url', 'order', 'isActive', 'createdAt']) &&
             validStringLength('title', 1, 100) &&
             isValidUrl(request.resource.data.url) &&
             request.resource.data.url.size() <= 500 &&
             request.resource.data.order is number &&
             request.resource.data.isActive is bool &&
             request.resource.data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Anyone can read profiles (public link aggregator)
      allow read: if true;
      
      // Only owner can create/update their profile
      allow create: if isOwner(userId) && isValidUser();
      allow update: if isOwner(userId) && isValidUser();
      allow delete: if isOwner(userId);
      
      match /links/{linkId} {
        // Anyone can read links
        allow read: if true;
        
        // Only owner can manage links
        allow create: if isOwner(userId) && isValidLink() && request.resource.data.createdAt == request.time;
        allow update: if isOwner(userId) && isValidLink() && areImmutableFieldsUnchanged(['createdAt']);
        allow delete: if isOwner(userId);
      }
    }
  }
}
